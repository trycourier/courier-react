{
  "name": "@trycourier/react-preferences",
  "version": "7.4.1",
  "main": "dist/index.js",
  "types": "typings/index.d.ts",
  "scripts": {
    "babel": "babel src -d dist --extensions \".ts,.tsx\" --ignore \"src/**/__tests__/**\"",
    "build:watch": "yarn babel --watch",
    "build": "rm -rf dist && yarn babel",
    "clean": "rm -rf dist typings",
    "readme": "concat-md --toc --decrease-title-levels --dir-name-as-title docs > README.md",
    "type-check": "tsc --noEmit",
    "types": "tsc --emitDeclarationOnly"
  },
  "peerDependencies": {
    "@trycourier/react-provider": ">=4.X.X",
    "react": ">=17.X.X",
    "react-dom": ">=17.X.X",
    "styled-components": ">=5.X.X"
  },
  "files": [
    "dist/",
    "typings/"
  ],
  "license": "ISC",
  "dependencies": {
    "@trycourier/react-hooks": "^7.4.1",
    "date-fns": "^2.19.0",
    "date-fns-tz": "^2.0.0",
    "react-toggle": "^4.1.2"
  },
  "gitHead": "d40638863e9bb860eaa9e08df26e2a9ef7ed41b9"
}
