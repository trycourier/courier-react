{
  "name": "@trycourier/react-brand-designer",
  "version": "7.4.7",
  "description": "Embeddable brand designer for multi-channel notifications",
  "homepage": "https://github.com/trycourier/courier-react/tree/main/packages/react-elements#readme",
  "license": "ISC",
  "main": "dist/index.js",
  "types": "typings/index.d.ts",
  "files": [
    "dist/",
    "typings/"
  ],
  "publishConfig": {
    "registry": "https://registry.yarnpkg.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trycourier/courier-react.git"
  },
  "scripts": {
    "babel": "babel src -d dist --extensions \".ts,.tsx\" --ignore \"src/**/__tests__/**\"",
    "build:watch": "yarn babel --watch",
    "build": "node ../../scripts/rm.js dist && yarn babel",
    "clean": "node ../../scripts/rm.js dist typings",
    "type-check": "tsc --noEmit",
    "types": "tsc --emitDeclarationOnly"
  },
  "bugs": {
    "url": "https://github.com/trycourier/courier-react/issues"
  },
  "dependencies": {
    "@trycourier/react-elements": "^7.4.7"
  },
  "peerDependencies": {
    "deep-extend": "0.6.x",
    "react": ">=17.X.X",
    "react-dom": ">=17.X.X",
    "styled-components": ">=5.X.X"
  },
  "gitHead": "39944f8461b285f34ae186bfbf5c70e9ab081875"
}
