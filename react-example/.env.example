# Environment Variables Example
# Copy this file to .env and update with your actual values

# API Configuration
REACT_APP_API_URL=https://api.example.com
REACT_APP_API_KEY=your-api-key-here

# App Configuration
REACT_APP_APP_NAME=React Example App
REACT_APP_ENVIRONMENT=development

# Feature Flags
REACT_APP_ENABLE_FEATURE_X=true
REACT_APP_ENABLE_FEATURE_Y=false

# Courier Configuration
REACT_APP_COURIER_CLIENT_KEY=your-courier-client-key
REACT_APP_COURIER_USER_ID=your-user-id
REACT_APP_COURIER_API_URL=https://api.courier.com
# Optional: Use authorization token instead of clientKey/userId
# REACT_APP_COURIER_AUTHORIZATION=your-authorization-token
